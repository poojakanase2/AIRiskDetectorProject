// Example Jenkinsfile with corrected Test stage
pipeline {
    agent any
    stages {
        stage('Build') {
            steps {
                echo 'Building project...'
            }
        }
        stage('Test') {
            steps {
                echo 'Running tests...'
                // Replace the following line with your actual test command
                sh 'npm test' // or 'mvn test', 'pytest', etc.
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying...'
            }
        }
    }
}
