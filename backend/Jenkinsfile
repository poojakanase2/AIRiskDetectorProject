// Example correction
pipeline {
  agent any
  stages {
    stage('Build') {
      steps {
        echo 'Building project...'
      }
    }
    stage('Test') {
      steps {
        echo 'Running tests...'
        sh 'exit 0' // Changed from exit 1 to exit 0
      }
    }
    stage('Deploy') {
      steps {
        echo 'Deploying...'
      }
    }
  }
}