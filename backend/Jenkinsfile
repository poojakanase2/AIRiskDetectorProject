pipeline {
    agent any
    environment {
        JENKINS_URL = 'http://your-jenkins-url'
        JENKINS_TOKEN = 'your-api-token'
    }
    stages {
        stage('Validate Jenkins Config') {
            steps {
                script {
                    if (!env.JENKINS_URL || !env.JENKINS_TOKEN) {
                        error('Jenkins URL and Token must be configured.')
                    }
                }
            }
        }
        stage('Build') {
            steps {
                echo 'Building...'
            }
        }
    }
}